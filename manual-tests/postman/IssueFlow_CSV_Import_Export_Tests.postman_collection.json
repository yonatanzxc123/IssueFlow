    {
      "name": "05 - Create ticket with comma and quotes",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Export ticket, comma {{runId}}\",\n  \"description\": \"Description with \\\"quotes\\\" and comma, plus newline\\\\nsecond line\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"type\": \"BUG\",\n  \"projectId\": \"{{projectId}}\",\n  \"assigneeId\": \"{{devId}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
