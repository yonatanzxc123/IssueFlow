              "pm.collectionVariables.set('normalTicketId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Export tickets CSV",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tickets/export?projectId={{projectId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets",
            "export"
          ],
          "query": [
            {
              "key": "projectId",
              "value": "{{projectId}}"
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Content-Type is CSV-ish', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv'); });",
              "pm.test('CSV header is exact', function () { pm.expect(pm.response.text().split(/\\r?\\n/)[0]).to.eql('id,title,description,status,priority,type,assigneeId'); });",
              "pm.test('CSV contains created tickets', function () { const text = pm.response.text(); pm.expect(text).to.include('Normal export ticket'); pm.expect(text).to.include('Export ticket, comma'); });",
              "pm.test('CSV appears to quote comma/quote field', function () { const text = pm.response.text(); pm.expect(text).to.include('\"Export ticket, comma'); pm.expect(text).to.include('\"\"quotes\"\"'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Import valid CSV file",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tickets/import",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets",
            "import"
          ],
          "query": []
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "projectId",
              "value": "{{projectId}}",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Valid import created 2', function () { pm.expect(json.created).to.eql(2); });",
              "pm.test('Valid import failed 0', function () { pm.expect(json.failed).to.eql(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - Import mixed CSV file continues after bad rows",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tickets/import",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets",
            "import"
          ],
          "query": []
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "projectId",
              "value": "{{projectId}}",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Mixed import created valid rows', function () { pm.expect(json.created).to.eql(2); });",
              "pm.test('Mixed import failed invalid rows', function () { pm.expect(json.failed).to.be.at.least(2); });",
              "pm.test('Mixed import has errors', function () { pm.expect(json.errors.length).to.be.at.least(2); });"
            ]
          }
        }
      ]
    },
