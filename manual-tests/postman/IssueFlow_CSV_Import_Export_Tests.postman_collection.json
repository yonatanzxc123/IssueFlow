        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('ticketWithCommaId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Create normal ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Normal export ticket {{runId}}\",\n  \"description\": \"Normal description\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"HIGH\",\n  \"type\": \"FEATURE\",\n  \"projectId\": \"{{projectId}}\",\n  \"assigneeId\": \"{{devId}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
