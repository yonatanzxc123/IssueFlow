{
  "info": {
    "name": "IssueFlow CSV Import Export Tests",
    "_postman_id": "3b8c1f10-csv-import-export",
    "description": "Manual smoke-test collection for IssueFlow CSV import/export. For import requests, select the provided CSV files in Postman form-data file field.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) { pm.collectionVariables.set('runId', Date.now().toString()); }",
          "if (!pm.collectionVariables.get('baseUrl')) { pm.collectionVariables.set('baseUrl', 'http://localhost:8080'); }"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "runId",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "adminId",
      "value": ""
    },
    {
      "key": "devId",
      "value": ""
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "ticketWithCommaId",
      "value": ""
    },
    {
      "key": "normalTicketId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "00 - Reset runId and variables",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"dummy\",\n  \"password\": \"dummy\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runId', Date.now().toString());",
              "['adminToken','adminId','devId','projectId','ticketWithCommaId','normalTicketId'].forEach(k => pm.collectionVariables.unset(k));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "01 - Create ADMIN user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin_csv_{{runId}}\",\n  \"email\": \"admin_csv_{{runId}}@example.com\",\n  \"fullName\": \"Admin CSV Test\",\n  \"role\": \"ADMIN\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Login ADMIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
