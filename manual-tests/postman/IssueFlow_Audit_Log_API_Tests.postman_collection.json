{
  "info": {
    "name": "IssueFlow Audit Log API Tests",
    "_postman_id": "b8f20f23-issueflow-audit-log-api",
    "description": "Manual smoke-test collection for IssueFlow read-only Audit Log API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) { pm.collectionVariables.set('runId', Date.now().toString()); }",
          "if (!pm.collectionVariables.get('baseUrl')) { pm.collectionVariables.set('baseUrl', 'http://localhost:8080'); }"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "runId",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "adminId",
      "value": ""
    },
    {
      "key": "devId",
      "value": ""
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "ticketId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "00 - Reset runId and variables",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ],
          "query": []
        },
        "description": "Optional. Intentionally returns 401 but resets variables for a fresh unique run.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"dummy\",\n  \"password\": \"dummy\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runId', Date.now().toString());",
              "['adminToken','adminId','devId','projectId','ticketId'].forEach(k => pm.collectionVariables.unset(k));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
