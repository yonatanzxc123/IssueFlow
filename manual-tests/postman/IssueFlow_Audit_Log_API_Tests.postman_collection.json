    {
      "name": "07 - GET all audit logs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/audit-logs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "audit-logs"
          ],
          "query": []
        },
        "description": "",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Response is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
              "pm.test('Contains at least one audit log', function () { pm.expect(pm.response.json().length).to.be.above(0); });",
              "pm.test('Newest first by timestamp', function () {",
              "  const arr = pm.response.json();",
              "  for (let i = 1; i < arr.length; i++) {",
              "    pm.expect(new Date(arr[i-1].timestamp).getTime()).to.be.at.least(new Date(arr[i].timestamp).getTime());",
              "  }",
              "});",
              "pm.test('Audit response has expected fields', function () {",
              "  const first = pm.response.json()[0];",
              "  ['id','action','entityType','entityId','actor','timestamp'].forEach(k => pm.expect(first).to.have.property(k));",
              "});"
            ]
          }
        }
      ]
    },
