          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Combined filter returns matching project create log', function () {",
              "  const id = Number(pm.collectionVariables.get('projectId'));",
              "  const arr = pm.response.json();",
              "  pm.expect(arr.length).to.be.at.least(1);",
              "  arr.forEach(l => {",
              "    pm.expect(l.entityType).to.eql('PROJECT');",
              "    pm.expect(l.entityId).to.eql(id);",
              "    pm.expect(l.action).to.eql('CREATE_PROJECT');",
              "    pm.expect(l.actor).to.eql('USER');",
              "  });",
              "});"
            ]
          }
        }
      ]
