    {
      "name": "12 - Combined filter PROJECT + projectId + CREATE_PROJECT + USER",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/audit-logs?entityType=PROJECT&entityId={{projectId}}&action=CREATE_PROJECT&actor=USER",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "audit-logs"
          ],
          "query": [
            {
              "key": "entityType",
              "value": "PROJECT"
            },
            {
              "key": "entityId",
              "value": "{{projectId}}"
            },
            {
              "key": "action",
              "value": "CREATE_PROJECT"
            },
            {
              "key": "actor",
              "value": "USER"
