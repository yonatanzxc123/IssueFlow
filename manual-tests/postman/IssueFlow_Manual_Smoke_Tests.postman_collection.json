            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ],
          "query": []
        },
        "description": "This request intentionally returns 401 but resets runId for a fresh test run. You may skip it.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"dummy\",\n  \"password\": \"dummy\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runId', Date.now().toString());",
              "pm.collectionVariables.unset('adminToken');",
              "pm.collectionVariables.unset('devToken');",
              "pm.collectionVariables.unset('adminId');",
              "pm.collectionVariables.unset('devId');",
              "pm.collectionVariables.unset('projectId');",
              "pm.collectionVariables.unset('ticketId');",
              "pm.collectionVariables.unset('deleteTicketId');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
