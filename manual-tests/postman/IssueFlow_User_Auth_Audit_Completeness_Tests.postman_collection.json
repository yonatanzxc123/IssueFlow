            },
            {
              "key": "entityId",
              "value": "{{targetUserId}}"
            }
          ]
        },
        "description": "",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('UPDATE_USER audit returned', function () { pm.expect(pm.response.json().length).to.be.at.least(1); });",
              "pm.test('All returned logs are UPDATE_USER for target user', function () {",
              "  const id = Number(pm.collectionVariables.get('targetUserId'));",
              "  pm.response.json().forEach(l => {",
              "    pm.expect(l.action).to.eql('UPDATE_USER');",
              "    pm.expect(l.entityType).to.eql('USER');",
              "    pm.expect(l.entityId).to.eql(id);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
