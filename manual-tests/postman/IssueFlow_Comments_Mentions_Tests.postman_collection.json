          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ],
          "query": []
        },
        "description": "Optional. Intentionally returns 401, but resets collection variables for a fresh unique run.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"dummy\",\n  \"password\": \"dummy\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runId', Date.now().toString());",
              "['adminToken','devToken','adminId','devId','mentionedUserId','projectId','ticketId','plainCommentId','mentionCommentId','duplicateMentionCommentId','unknownMentionCommentId'].forEach(k => pm.collectionVariables.unset(k));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
