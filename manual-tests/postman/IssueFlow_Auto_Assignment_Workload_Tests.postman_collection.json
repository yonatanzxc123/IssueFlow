          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Workload returns developers only and excludes admin', function () { const arr = pm.response.json(); const adminId = Number(pm.collectionVariables.get('adminId')); pm.expect(arr.some(w => w.userId === adminId)).to.eql(false); });",
              "pm.test('Workload includes dev1, dev2, dev3', function () { const arr = pm.response.json(); const ids = arr.map(w => w.userId); pm.expect(ids).to.include(Number(pm.collectionVariables.get('dev1Id'))); pm.expect(ids).to.include(Number(pm.collectionVariables.get('dev2Id'))); pm.expect(ids).to.include(Number(pm.collectionVariables.get('dev3Id'))); });"
            ]
          }
        }
      ]
    },
