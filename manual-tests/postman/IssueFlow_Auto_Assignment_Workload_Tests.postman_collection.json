          "mode": "raw",
          "raw": "{\n  \"username\": \"admin_workload_{{runId}}\",\n  \"email\": \"admin_workload_{{runId}}@example.com\",\n  \"fullName\": \"Admin Workload Test\",\n  \"role\": \"ADMIN\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminId', json.id);"
