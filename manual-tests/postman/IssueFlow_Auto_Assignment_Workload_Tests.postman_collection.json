    {
      "name": "07 - Create explicit ticket assigned to DEV 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Explicit assignee ticket {{runId}}\",\n  \"description\": \"Creates workload for dev1\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"type\": \"BUG\",\n  \"projectId\": \"{{projectId}}\",\n  \"assigneeId\": \"{{dev1Id}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('explicitTicketId', json.id);",
              "pm.test('Explicit assignee is dev1', function () { pm.expect(pm.response.json().assigneeId).to.eql(Number(pm.collectionVariables.get('dev1Id'))); });"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Create unassigned ticket should auto-assign least loaded DEVELOPER",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Auto-assigned ticket {{runId}}\",\n  \"description\": \"No assigneeId should trigger auto-assignment\",\n  \"status\": \"TODO\",\n  \"priority\": \"HIGH\",\n  \"type\": \"FEATURE\",\n  \"projectId\": \"{{projectId}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('autoTicketId', json.id);",
              "pm.test('Auto-assigned ticket did not go to ADMIN', function () { pm.expect(pm.response.json().assigneeId).to.not.eql(Number(pm.collectionVariables.get('adminId'))); });",
              "pm.test('Auto-assigned ticket avoids loaded dev1', function () { pm.expect(pm.response.json().assigneeId).to.not.eql(Number(pm.collectionVariables.get('dev1Id'))); });",
              "pm.test('Auto-assigned ticket assigned to a developer', function () { const id = pm.response.json().assigneeId; pm.expect([Number(pm.collectionVariables.get('dev2Id')), Number(pm.collectionVariables.get('dev3Id'))]).to.include(id); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - Get workload for main project",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/projects/{{projectId}}/workload",
          "host": [
