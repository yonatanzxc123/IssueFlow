    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "runId",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "adminId",
      "value": ""
    },
    {
      "key": "dev1Id",
      "value": ""
