            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Workload endpoint still works after DONE transition', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
              "pm.test('Dev1 workload is at least 1 due to auto ticket patched to dev1', function () { const dev1 = pm.response.json().find(w => w.userId === Number(pm.collectionVariables.get('dev1Id'))); pm.expect(dev1).to.not.eql(undefined); pm.expect(dev1.openTicketCount).to.be.at.least(1); });"
            ]
          }
        }
