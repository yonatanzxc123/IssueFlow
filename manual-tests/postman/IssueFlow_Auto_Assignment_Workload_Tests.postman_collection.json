  "item": [
    {
      "name": "00 - Reset runId and variables",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"dummy\",\n  \"password\": \"dummy\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runId', Date.now().toString());",
              "['adminToken','adminId','dev1Id','dev2Id','dev3Id','projectId','explicitTicketId','autoTicketId'].forEach(k => pm.collectionVariables.unset(k));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
