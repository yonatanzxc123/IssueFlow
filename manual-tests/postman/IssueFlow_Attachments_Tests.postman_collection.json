        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Attachment Project {{runId}}\",\n  \"description\": \"Manual attachment test project\",\n  \"ownerId\": \"{{devId}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('projectId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Create ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Attachment test ticket {{runId}}\",\n  \"description\": \"Ticket for attachment tests\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"type\": \"BUG\",\n  \"projectId\": \"{{projectId}}\",\n  \"assigneeId\": \"{{devId}}\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('ticketId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Upload valid text attachment",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tickets/{{ticketId}}/attachments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets",
            "{{ticketId}}",
            "attachments"
          ],
          "query": []
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('attachmentId', json.id);",
              "pm.test('Attachment metadata returned', function () { const json = pm.response.json(); pm.expect(json.filename).to.exist; pm.expect(json.contentType).to.exist; pm.expect(json.sizeBytes).to.be.above(0); });",
              "pm.test('No raw file content in response', function () { pm.expect(pm.response.text()).to.not.include('content'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - List attachments for ticket",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tickets/{{ticketId}}/attachments",
