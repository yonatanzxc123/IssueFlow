      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('List contains uploaded attachment', function () { const id = Number(pm.collectionVariables.get('attachmentId')); pm.expect(pm.response.json().some(a => a.id === id)).to.eql(true); });"
            ]
          }
        }
      ]
    },
